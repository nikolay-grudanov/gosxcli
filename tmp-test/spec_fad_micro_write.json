{
  "type": "fad_macro",
  "title": "UC-01 → Шаг 3: Генерация DOCX (микрошаг)",
  "actor": "Пользователь",
  "page": {"w": 1500, "h": 1200},
  "steps": [
    {
      "label": "DocxWriter.write()\n: IRDocument → Document",
      "io":   "IRDocument",
      "rule": "python-docx API:\nне создавать XML\nнапрямую",
      "tool": "writers/docx_writer.py"
    },
    {
      "label": "_write_heading()\n: HeadingNode → paragraphs",
      "io":   "paragraphs (H1-H3)",
      "rule": "Times New Roman 14pt,\nчёрный цвет заголовков",
      "tool": "writers/styles.py"
    },
    {
      "label": "_write_table()\n: TableNode → table w/ gridSpan",
      "io":   "tables",
      "rule": "colspan/rowspan\nчерез gridSpan + vMerge",
      "tool": "writers/tables.py"
    },
    {
      "label": "_write_figure()\n: FigureNode → картинка + caption",
      "io":   "images",
      "rule": "figcaption style 'af2',\nномер Figure N.M",
      "tool": "writers/images.py"
    },
    {
      "label": "_write_math()\n: MathNode → OMML (mml2omml)",
      "io":   "math (OMML)",
      "rule": "latex2mathml → MathML\n→ OMML для Word",
      "tool": "writers/mml2omml.py"
    },
    {
      "label": "_write_code_block()\n: CodeBlockNode → monospace + pygments",
      "io":   "code blocks",
      "rule": "VS Code Dark+ scheme,\nescaped XML",
      "tool": "writers/code_highlighter.py"
    }
  ]
}