{
  "type": "fad_macro",
  "title": "UC-01 → Шаг 2: Парсинг Typst → IR (микрошаг)",
  "actor": "Пользователь",
  "page": {"w": 1500, "h": 1200},
  "steps": [
    {
      "label": "TypstScanner.tokenize()\n→ Iterator[Token]",
      "io":   "input.typ",
      "rule": "Пропуск whitespace\nперед LABEL token",
      "tool": "parser/scanner.py"
    },
    {
      "label": "TypstQueryParser.parse()\n→ AST (поток событий)",
      "io":   "tokens",
      "rule": "Поддержка вложенных\nскобок () и []",
      "tool": "parser/typst_query_parser.py\nparser/unified_parser.py"
    },
    {
      "label": "unified_parser →\nIRBuilder.dispatch()",
      "io":   "AST",
      "rule": "4-слойный IR:\nIngest→Parser→IR→Writer",
      "tool": "parser/unified_parser.py\nir/model.py"
    },
    {
      "label": "IRDocument:\nHeadingNode / ParaNode /\nTableNode / CodeBlock...",
      "io":   "IRDocument",
      "rule": "Pydantic v2 BaseModel:\nвалидация типов",
      "tool": "ir/model.py"
    },
    {
      "label": "ReferenceValidator:\n@label → CrossRefNode,\n@[key] → CiteNode",
      "rule": "Двунаправленная\nвалидация ссылок",
      "tool": "ir/validator.py\nparser/refs.py"
    }
  ]
}